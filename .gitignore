
# Dataset và dữ liệu MRI (dung lượng lớn, không push lên git)
dataset/*
!dataset/derivatives/
!dataset/.gitkeep

# Keep OASIS folder structures but ignore the actual datasets
oasis/o1/*
!oasis/o1/.gitkeep
oasis/o1_using/*
!oasis/o1_using/.gitkeep
oasis/o2/*
!oasis/o2/.gitkeep
oasis/o2_using/*
!oasis/o2_using/.gitkeep

# Python virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Build artifacts
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
